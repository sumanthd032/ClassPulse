# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=classpulse
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=classpulse
DATABASE_URL=postgresql+asyncpg://classpulse:change_me_in_production@db:5432/classpulse

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_API_KEY=your_openai_or_gemini_api_key
LLM_MODEL=gpt-4o-mini        # or gemini-1.5-flash
LLM_MAX_CALLS_PER_STUDENT_PER_HOUR=5

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads       # local dev
AWS_S3_BUCKET=                # set in production
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ── App ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DEBUG=false
ENVIRONMENT=development       # development | production
