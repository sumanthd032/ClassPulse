# ============================================================
# ClassPulse Backend — Environment Variables
# ============================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Database -------------------------------------------------
# asyncpg driver: postgresql+asyncpg://user:password@host:port/db
DATABASE_URL=postgresql+asyncpg://classpulse:password@db:5432/classpulse

# --- Redis ----------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- JWT Authentication ---------------------------------------
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM (Google Gemini) --------------------------------------
# Get your key from https://aistudio.google.com/app/apikey
LLM_API_KEY=your-gemini-api-key-here
# Available models: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
LLM_MODEL=gemini-2.0-flash

# --- Feature Flags --------------------------------------------
# Max AI feedback calls per student per hour (default: 5)
LLM_RATE_LIMIT_PER_HOUR=5

# --- SMTP / Email (optional) -----------------------------------
# Leave SMTP_HOST empty to disable email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@classpulse.app
EMAIL_ENABLED=false

# --- File Uploads ---------------------------------------------
UPLOAD_DIR=/uploads
MAX_UPLOAD_SIZE_MB=10

# --- CORS -----------------------------------------------------
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
