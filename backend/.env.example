# Copy root .env.example — backend reads from the root .env via docker-compose env_file
# This file is for running the backend standalone (outside Docker)

DATABASE_URL=postgresql+asyncpg://classpulse:classpulse_secret@localhost:5432/classpulse
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=dev_secret_change_in_prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
LLM_API_KEY=your_key_here
LLM_MODEL=gpt-4o-mini
CORS_ORIGINS=http://localhost:5173
DEBUG=true
ENVIRONMENT=development
